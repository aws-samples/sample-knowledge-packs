# Local environment configuration
# Copy this file to .env and fill in your values
#
# CUSTOM_DOMAIN: Your custom domain for the MCP endpoint (e.g., knowledge-packs.example.com)
# ZONE_NAME:     The Route 53 hosted zone (e.g., example.com)
# HOSTED_ZONE_ID: The Route 53 hosted zone ID (e.g., Z0123456789ABCDEFGHIJ)
# MCP_ENDPOINT:  Full MCP endpoint URL (e.g., https://knowledge-packs.example.com/mcp)

CUSTOM_DOMAIN=knowledge-packs.example.com
ZONE_NAME=example.com
HOSTED_ZONE_ID=
MCP_ENDPOINT=https://knowledge-packs.example.com/mcp
